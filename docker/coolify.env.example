# Secretos para Coolify → Environment Variables
# Copiar solo los valores marcados como SECRETO. El resto ya va hardcodeado en docker-compose.coolify.yml
#
# Generar APP_KEY (en local con PHP):
#   php artisan key:generate --show
#
# Generar passwords MySQL:
#   openssl rand -base64 24

# ── Obligatorios para primer deploy ──
APP_KEY=base64:REEMPLAZAR
DB_DATABASE=controclinic
DB_USERNAME=controclinic
DB_PASSWORD=REEMPLAZAR
MYSQL_ROOT_PASSWORD=REEMPLAZAR

# ── Mail (Resend — configurar después del primer deploy) ──
# MAIL_HOST=smtp.resend.com
# MAIL_PORT=587
# MAIL_USERNAME=resend
# MAIL_PASSWORD=re_REEMPLAZAR
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS=noreply@controclinic.com

# ── Paddle (Fase D — opcional en primer deploy) ──
# PADDLE_SELLER_ID=
# PADDLE_CLIENT_SIDE_TOKEN=
# PADDLE_API_KEY=
# PADDLE_WEBHOOK_SECRET=
# PADDLE_SANDBOX=true

# ── Sentry (opcional) ──
# SENTRY_LARAVEL_DSN=
