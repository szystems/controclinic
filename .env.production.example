# =============================================================================
# ControClinic — Plantilla de Variables de Entorno para PRODUCCIÓN
# =============================================================================
# Copia este archivo como .env en tu servidor y completa cada valor.
# NUNCA subas el .env real a control de versiones.
# Genera la clave de aplicación con: php artisan key:generate
# =============================================================================

# ─── Aplicación ──────────────────────────────────────────────────────────────
APP_NAME=ControClinic
APP_ENV=production
APP_KEY=                        # REQUERIDO — php artisan key:generate
APP_DEBUG=false                 # SIEMPRE false en producción
APP_URL=https://tudominio.com   # URL pública con HTTPS

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# ─── Seguridad ────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12                # Aumentar a 13-14 si el hardware lo permite

# ─── Logs ────────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=daily                 # Rotar logs diariamente
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning               # En prod: warning o error (no debug)

# ─── Base de Datos (MySQL 8.0) ────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1               # o IP/hostname de tu servidor MySQL
DB_PORT=3306
DB_DATABASE=controclinic_prod
DB_USERNAME=controclinic_user
DB_PASSWORD=                    # REQUERIDO — contraseña segura

# ─── Sesiones ────────────────────────────────────────────────────────────────
SESSION_DRIVER=database         # 'database' o 'redis' en producción
SESSION_LIFETIME=120            # minutos
SESSION_ENCRYPT=true            # SIEMPRE true en producción
SESSION_PATH=/
SESSION_DOMAIN=.tudominio.com   # Con punto para subdominios
SESSION_SECURE_COOKIE=true      # REQUERIDO con HTTPS

# ─── Cache ───────────────────────────────────────────────────────────────────
CACHE_STORE=redis               # 'redis' o 'database'
# CACHE_PREFIX=controclinic_

# ─── Redis (recomendado en producción) ───────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=                 # Establecer contraseña en producción
REDIS_PORT=6379

# ─── Colas ───────────────────────────────────────────────────────────────────
QUEUE_CONNECTION=redis          # 'redis' o 'database'
BROADCAST_CONNECTION=log

# ─── Almacenamiento ──────────────────────────────────────────────────────────
FILESYSTEM_DISK=local           # Cambiar a 's3' si usas AWS S3

# ─── AWS S3 (opcional — para almacenamiento de archivos) ─────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=controclinic-prod
# AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── Correo ──────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp                # smtp, mailgun, ses, postmark
MAIL_SCHEME=tls
MAIL_HOST=smtp.tuproveedor.com
MAIL_PORT=587
MAIL_USERNAME=                  # REQUERIDO
MAIL_PASSWORD=                  # REQUERIDO
MAIL_FROM_ADDRESS="noreply@tudominio.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Paddle (Facturación / Suscripciones) ────────────────────────────────────
PADDLE_SELLER_ID=               # REQUERIDO — tu Seller ID de Paddle
PADDLE_CLIENT_SIDE_TOKEN=       # REQUERIDO — token para el frontend
PADDLE_API_KEY=                 # REQUERIDO — API key de Paddle
PADDLE_WEBHOOK_SECRET=          # REQUERIDO — secreto para verificar webhooks
PADDLE_SANDBOX=false            # SIEMPRE false en producción

# IDs de precios de Paddle (obtener desde el panel de Paddle)
PADDLE_PRICE_SOLO_MONTHLY=
PADDLE_PRICE_SOLO_YEARLY=
PADDLE_PRICE_GROUP_MONTHLY=
PADDLE_PRICE_GROUP_YEARLY=
PADDLE_PRICE_ENTERPRISE_MONTHLY=
PADDLE_PRICE_ENTERPRISE_YEARLY=

# ─── Frontend / Vite ─────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"

# =============================================================================
# CHECKLIST ANTES DE IR A PRODUCCIÓN
# =============================================================================
# [ ] APP_KEY generada y guardada de forma segura
# [ ] APP_DEBUG=false
# [ ] SESSION_ENCRYPT=true y SESSION_SECURE_COOKIE=true
# [ ] DB_PASSWORD segura (mínimo 32 caracteres)
# [ ] MAIL_* configurado y probado
# [ ] PADDLE_SANDBOX=false con credenciales de producción
# [ ] PADDLE_WEBHOOK_SECRET configurado y URL registrada en Paddle
# [ ] redis configurado con contraseña
# [ ] php artisan config:cache && php artisan route:cache && php artisan view:cache
# [ ] php artisan storage:link ejecutado
# [ ] Cron configurado: * * * * * php /ruta/artisan schedule:run
# [ ] Queue worker corriendo: php artisan queue:work --daemon
# =============================================================================
