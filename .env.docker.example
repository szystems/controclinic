APP_NAME=ControClinic
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8088

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=controclinic
DB_USERNAME=controclinic
DB_PASSWORD=changeme
DB_ROOT_PASSWORD=changeme

SESSION_DRIVER=redis
SESSION_LIFETIME=120

QUEUE_CONNECTION=redis
CACHE_STORE=redis

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@controclinic.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# Paddle Billing (Sandbox)
PADDLE_SELLER_ID=
PADDLE_CLIENT_SIDE_TOKEN=
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_SANDBOX=true

PADDLE_PRICE_SOLO_MONTHLY=
PADDLE_PRICE_SOLO_YEARLY=
PADDLE_PRICE_GROUP_MONTHLY=
PADDLE_PRICE_GROUP_YEARLY=
PADDLE_PRICE_ENTERPRISE_MONTHLY=
PADDLE_PRICE_ENTERPRISE_YEARLY=

# Forward ports (host -> container)
FORWARD_APP_PORT=8088
FORWARD_DB_PORT=33060
FORWARD_REDIS_PORT=63790
